[9.181587, "o", "\r\n\u001b[1m\u001b[0;36m3. Testing all 5 model tiers\u001b[0m\r\n"]
[9.185098, "o", "\u001b[2m────────────────────────────\u001b[0m\r\n"]
[9.686198, "o", "\r\n\u001b[1;33mnvidia-auto\u001b[0m — routes to fastest across ALL models\r\n"]
[112.532774, "o", "  \u001b[0;32mModel:\u001b[0m    nvidia-auto\r\n  \u001b[0;32mRouted:\u001b[0m   nvidia-auto\r\n  \u001b[0;32mLatency:\u001b[0m  102796ms\r\n  \u001b[0;32mResponse:\u001b[0m 4\r\n\r\n"]
[113.534155, "o", "\u001b[1;33mnvidia-coding\u001b[0m — coding specialists\r\n"]
[114.720404, "o", "  \u001b[0;32mModel:\u001b[0m    nvidia-coding\r\n  \u001b[0;32mRouted:\u001b[0m   nvidia-coding\r\n  \u001b[0;32mLatency:\u001b[0m  1135ms\r\n"]
[114.720534, "o", "  \u001b[0;32mResponse:\u001b[0m Here's a Python one-liner to reverse a string:  ```python s = \"hello\"[::-1] ```  Or as a reusable one-liner function:  `\r\n\r\n"]
[115.722184, "o", "\u001b[1;33mnvidia-reasoning\u001b[0m — reasoning models\r\n"]
[123.764287, "o", "  \u001b[0;32mModel:\u001b[0m    nvidia-reasoning\r\n  \u001b[0;32mRouted:\u001b[0m   nvidia_nim/meta/llama-4-maverick-17b-128e-instruct\r\n  \u001b[0;32mLatency:\u001b[0m  7993ms\r\n  \u001b[0;32mResponse:\u001b[0m 36\r\n\r\n"]
[124.765573, "o", "\u001b[1;33mnvidia-fast\u001b[0m — small efficient models\r\n"]
[239.809849, "o", "  \u001b[0;32mModel:\u001b[0m    nvidia-fast\r\n  \u001b[0;32mRouted:\u001b[0m   nvidia_nim/meta/llama-3.3-70b-instruct\r\n  \u001b[0;32mLatency:\u001b[0m  114996ms\r\n  \u001b[0;32mResponse:\u001b[0m Hello\r\n\r\n"]
