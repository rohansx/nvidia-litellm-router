# Required: NVIDIA NIM API key (free at https://build.nvidia.com/settings/api-keys)
NVIDIA_API_KEY=nvapi-xxxx

# Optional: Additional free providers for more failover coverage
OPENCODE_API_KEY=           # OpenCode Zen: Big Pickle, MiniMax, MiMo free models
GROQ_API_KEY=               # Groq: Llama 70B, Mixtral (30 RPM free)
CEREBRAS_API_KEY=           # Cerebras: Llama 70B (ultra-fast inference, 30 RPM free)

# Optional: Slack alerting for proxy errors
SLACK_WEBHOOK_URL=
